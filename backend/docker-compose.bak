version: "3.9"

services:
  circuitlab-backend:
    build:
      context: /volume1/docker/circuitlab/backend
      network: host
    container_name: circuitlab-backend
    restart: unless-stopped
    volumes:
      - /volume1/docker/circuitlab/backend/data:/app/data
    ports:
      - "8000:8000"
    dns:
      - 8.8.8.8
      - 1.1.1.1

  circuitlab-ui:
    image: nginx:alpine
    container_name: circuitlab-ui
    restart: unless-stopped
    depends_on:
      - circuitlab-backend
    ports:
      - "8080:80"
    volumes:
      - /volume1/docker/circuitlab/web:/usr/share/nginx/html:ro
      - /volume1/docker/circuitlab/nginx/default.conf:/etc/nginx/conf.d/default.conf:ro
    dns:
      - 8.8.8.8
      - 1.1.1.1